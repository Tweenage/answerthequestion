{
  "name": "atq-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:atq": "npm -w atq-app run dev",
    "dev:spelling": "npm -w spelling-app run dev",
    "build:atq": "npm -w atq-app run build",
    "build:spelling": "npm -w spelling-app run build",
    "build": "npm run build:atq && npm run build:spelling",
    "test:atq": "npm -w atq-app run test",
    "test:spelling": "npm -w spelling-app run test",
    "test": "npm run test:atq && npm run test:spelling",
    "lint": "npm -w atq-app run lint && npm -w spelling-app run lint"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lexend": "^5.2.11",
    "@fontsource/nunito": "^5.2.7"
  },
  "devDependencies": {
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "typescript-eslint": "^8.58.1"
  }
}
